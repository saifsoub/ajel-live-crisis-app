# ─── Authentication ────────────────────────────────────────────────────────────
# Change these before deploying!
AJEL_ADMIN_EMAIL=admin@ajel.local
AJEL_ADMIN_PASSWORD=ChangeThisNow!

# A long, random string used to sign session cookies.
# Generate one with: node scripts/generate-env.js
AJEL_SESSION_SECRET=replace-with-a-long-random-secret

# ─── AI (optional) ─────────────────────────────────────────────────────────────
# If omitted, the app falls back to deterministic heuristic insights.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── News sources (optional) ────────────────────────────────────────────────────
# NewsAPI key. If omitted, only GDELT + ReliefWeb are used.
NEWS_API_KEY=

# Application name sent to ReliefWeb API (identify your app).
RELIEFWEB_APPNAME=ajel-v2.local
